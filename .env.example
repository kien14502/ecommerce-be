# Database
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DB_NAME=ecommerce_db
MYSQL_SSL_MODE=disable
MYSQL_MAX_OPEN_CONNS=100
MYSQL_MAX_IDLE_CONNS=10
MYSQL_CONN_MAX_LIFETIME=3600

# Logger
LOGGER_LEVEL=debug
LOGGER_FILE_LOG_PATH=./storages/logs/app.log
LOGGER_MAX_SIZE=100
LOGGER_MAX_BACKUPS=7
LOGGER_MAX_AGE=30
LOGGER_COMPRESS=true

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=10

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_SECURE=true

# Kafka
KAFKA_HOST=localhost:9092

# JWT
JWT_ACCESS_KEY=your_access_key
JWT_REFRESH_KEY=your_refresh_key
JWT_ACCESS_EXP=5
JWT_REFRESH_EXP=24

# Server
SERVER_PORT=8000
SERVER_CORS=["http://localhost:5173", "http://localhost:3000"]
SERVER_VERSION=1.0.0